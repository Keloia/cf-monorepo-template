{
  "name": "cf-worker",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.1",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@eslint/js": "^10.0.1",
    "@secretlint/core": "^11.6.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.6.0",
    "@types/bun": "latest",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jscpd": "^4.0.8",
    "knip": "^6.3.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "secretlint": "^11.6.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.0",
    "wrangler": "^4.80.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "knip": "knip",
    "jscpd": "jscpd src/",
    "secretlint": "secretlint '**/*'",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.47.0",
    "hono": "^4.12.10"
  }
}
